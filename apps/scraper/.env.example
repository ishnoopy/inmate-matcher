# ===========================================
# SCRAPER CONFIGURATION (Optional)
# ===========================================
# Number of parallel browser workers for Madison scraper (default: 4)
SCRAPER_CONCURRENCY=4

# Run browser in headless mode (default: true, set to "false" to see browser)
SCRAPER_HEADLESS=true

# Slow down browser actions by N milliseconds for debugging (default: 0)
SCRAPER_SLOWMO_MS=0
