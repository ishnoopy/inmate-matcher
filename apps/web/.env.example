# ===========================================
# DATABASE (Required)
# ===========================================
# SQLite database URL (file path relative to apps/web)
DATABASE_URL="file:./data/inmate-matcher.db"

# Trust the host for authentication
AUTH_TRUST_HOST=true

# ===========================================
# AUTHENTICATION (Required)
# ===========================================
# Session encryption secret
# Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-your-generated-secret"

# ===========================================
# OPENAI (Required for document detection)
# ===========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Encryption key for storing Gmail app passwords securely
# Generate with: openssl rand -hex 32
# Required only if using email notifications
ENCRYPTION_KEY="replace-with-your-encryption-key"

# ===========================================
# FEATURE FLAGS
# ===========================================
# Set to "true" to enable email alert sending (local development only).
# DigitalOcean droplets block outbound SMTP — keep this "false" until migrated
# to a third-party email service provider.
NEXT_PUBLIC_IS_EMAILING_ENABLED=true
